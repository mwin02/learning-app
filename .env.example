# Environment variables for the Adaptive Learning Path app.
# Populated per-feature as we add integrations. Copy to .env.local (git-ignored) and fill in.

# --- Phase 1: Vertex AI (Gemini) ---
# GCP setup steps: see Feature 1a in docs/ROADMAP.md.
# CREDENTIALS_JSON must be the FULL service-account JSON as a SINGLE LINE
# (no real newlines — `\n` inside the private_key string is fine and required).
# Flatten a downloaded key with:  jq -c . path/to/sa.json
# Paste the resulting one-line string verbatim into .env.local and into the
# Vercel dashboard env-var field. Real newlines will break JSON.parse at boot.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# --- Phase 1: Supabase Postgres (Prisma) ---
# DATABASE_URL is the Supabase transaction-pooler URL (port 6543) — used by the
# app at runtime, locally and in production. Keep it pointed at Supabase even in
# local dev; the app reads from the production DB.
# Source: Supabase → Project Settings → Database → Connection string.
# Ends with ?sslmode=require. Replace [YOUR-PASSWORD] with the project password.
DATABASE_URL=
#
# DIRECT_URL is consumed by the Prisma CLI for migrations and `db pull` (see
# prisma.config.ts). For local development this MUST point at the local Docker
# Postgres so `prisma migrate dev` never touches prod. See docs/db-setup.md.
# Local value (matches docker-compose.yml):
DIRECT_URL=postgresql://postgres:postgres@localhost:55432/learning_app
# In Vercel, DIRECT_URL is set to the Supabase direct connection (port 5432) so
# `prisma migrate deploy` can run during build.

# --- Phase 2d: placeholder auth gate ---
# Set to "1" locally to satisfy the withAuth middleware (src/lib/api/with-auth.ts).
# Without it, any route wrapped in withAuth returns 404. Phase 3 replaces this
# with a real Supabase session check; this flag goes away then.
DEV_AUTH=

# --- Phase 3: Supabase Auth (added when Phase 3 starts) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 3: Stripe ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
