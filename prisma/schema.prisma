// Prisma schema for the Adaptive Learning Path app.
// Prisma 7 moved connection URLs out of schema.prisma into prisma.config.ts.
// Runtime DB connection is set up in src/lib/db.ts via @prisma/adapter-pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  topic                String
  title                String
  url                  String         @unique
  type                 ResourceType
  tier                 ResourceTier   @default(core)
  durationMin          Int
  summary              String
  difficulty           Difficulty
  prerequisiteConcepts String[]
  conceptsTaught       String[]
  requiresPurchase     Boolean        @default(false)
  origin               Origin         @default(seed)
  status               ResourceStatus @default(active)
  language             String         @default("en")
  trustScore           Float          @default(0.5)
  attribution          String?
  sourceId             String
  source               Source         @relation(fields: [sourceId], references: [id])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([topic, status, tier])
  @@index([difficulty])
  @@index([sourceId])
}

model Source {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  url        String
  kind       SourceKind
  trustScore Float      @default(0.5)
  resources  Resource[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([kind])
}

enum ResourceType {
  article
  video
  course
  interactive
  docs
  book
}

enum ResourceTier {
  core
  optional
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum Origin {
  seed
  agent
  user
}

enum SourceKind {
  official_docs
  educator
  course_platform
  textbook
  community
}

enum ResourceStatus {
  active
  deprecated
  pending_review
}
