// Prisma schema for the Adaptive Learning Path app.
// Prisma 7 moved connection URLs out of schema.prisma into prisma.config.ts.
// Runtime DB connection is set up in src/lib/db.ts via @prisma/adapter-pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  topic                String
  title                String
  url                  String         @unique
  type                 ResourceType
  tier                 ResourceTier   @default(core)
  durationMin          Int
  summary              String
  // Phase 2g: the resource body, in markdown. Null for the overwhelming majority of
  // rows (link-out resources — videos, docs, courseware: the content lives at `url`).
  // Populated only for `origin = generated` rows (the AI-authored on-ramp lesson),
  // where there is no external page and the body is stored inline.
  content              String?
  difficulty           Difficulty
  prerequisiteConcepts String[]
  conceptsTaught       String[]
  requiresPurchase     Boolean        @default(false)
  origin               Origin         @default(seed)
  status               ResourceStatus @default(active)
  // Set when a pending-review reject deprecates the row. `soft` = quality
  // downgrade (future tracks only); `hard` = broken/dead link (a future Track
  // layer may need to patch or flag in-flight learners). Null for rows that
  // were never rejected. See src/lib/curation/pending-review.ts.
  deprecationSeverity  DeprecationSeverity?
  language             String         @default("en")
  trustScore           Float          @default(0.5)
  // Phase 2.5h: raw engagement signals persisted so trustScore is RECOMPUTABLE
  // (when YouTube stats grow stale, or when our own up/down votes land as a second
  // evidence term). Populated only for YouTube resources sourced via the Data API
  // prong; null elsewhere. `youtubeChannelId` is the video's channel, used to
  // resolve the right Source prior — fixing the hostname-collision bug where every
  // youtube.com URL matched one seeded channel row. See curation/trust-score.ts.
  viewCount            Int?
  likeCount            Int?
  youtubeChannelId     String?
  attribution          String?
  sourceId             String
  source               Source         @relation(fields: [sourceId], references: [id])
  // Phase 2.5: container/atomic decomposition. This is a tree of arbitrary
  // depth: a container (decompositionStatus='decomposed') holds children, and a
  // child may itself be a 'decomposed' container (a path → its courses → their
  // lessons). Only leaves are 'atomic'. The root has a null parent; every other
  // node has a non-null parent. "Pickable" by the curriculum agent is DERIVED:
  // status='active' AND decompositionStatus='atomic' — i.e. any 'decomposed'
  // container (root OR intermediate) is not pickable, only its atomic leaves are.
  // Do not add a pickable column.
  parentResourceId     String?
  parent               Resource?      @relation("ResourceDecomposition", fields: [parentResourceId], references: [id], onDelete: SetNull)
  children             Resource[]     @relation("ResourceDecomposition")
  orderInParent        Int?
  decompositionStatus  DecompositionStatus @default(atomic)
  // Phase 2.5-AR: semantic search. `embedding` is a pgvector column (text-
  // embedding-005, 768 dims) over `title + summary + conceptsTaught`. Typed
  // Unsupported because Prisma has no native vector type — it is written and
  // queried only via raw SQL in src/lib/embeddings.ts, never through the
  // client. `embeddedAt` is the staleness signal: backfill re-embeds rows
  // where it is null or older than `updatedAt`. The hnsw index lives in the
  // migration SQL (Prisma can't express it). See ROADMAP Phase 2.5-AR.
  embedding            Unsupported("vector(768)")?
  embeddedAt           DateTime?
  // Phase 2.5j: cached frame-embeddability of `url`, classified once and amortized
  // across every Track built off this resource (it's a property of the URL/host,
  // not the per-Track context). `null` = never probed; the Track builder treats
  // null as not-embeddable (newtab) and the backfill targets `embedCheckedAt IS
  // NULL`. Set true via the YouTube allowlist (no network call) or a clean HEAD
  // header probe (no blocking X-Frame-Options / CSP frame-ancestors); false when a
  // blocking header is present. An inconclusive probe (network error/timeout)
  // leaves BOTH columns null so a later run retries. See lib/curation/embeddability.ts.
  embeddable           Boolean?
  embedCheckedAt       DateTime?
  lessonResources      LessonResource[]
  conceptResources     ConceptResource[]
  sourcedFor           ResourceSourcedFor[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([topic, status, tier])
  @@index([difficulty])
  @@index([sourceId])
  @@index([parentResourceId])
  @@unique([parentResourceId, orderInParent])
}

// Phase 2.5-AR (AR-5): persisted topic canonicalization registry. The topic
// gate's LLM tier mints a canonical slug for off-library topics; without memory
// it could map "go" one run and "golang" the next, partitioning the Resource
// library (which keys on an exact `topic` match). Each row records a normalized
// input phrasing (`alias`) → the canonical slug it resolved to. A repeat
// phrasing short-circuits the LLM; the distinct set of `canonical` values (plus
// the curated TOPIC_SLUGS) is the vocabulary the gate grounds the LLM on so new
// phrasings collapse onto existing slugs. Curated slugs are NOT seeded here —
// they short-circuit earlier and remain code-owned in src/types/resource.ts.
model TopicAlias {
  id        String   @id @default(cuid())
  alias     String   @unique
  canonical String
  subject   String
  createdAt DateTime @default(now())

  @@index([canonical])
}

model Source {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  url        String
  kind       SourceKind
  trustScore Float      @default(0.5)
  // Phase 2.5h: for YouTube-channel sources, the canonical channelId (UC…). The
  // Data API prong resolves a video's Source by matching this against the video's
  // channelId — hostname matching can't tell channels apart (all are youtube.com).
  // Null for non-YouTube sources. Unique so one channel maps to one Source.
  youtubeChannelId String? @unique
  resources  Resource[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([kind])
}

enum ResourceType {
  article
  video
  course
  interactive
  docs
  book
}

enum ResourceTier {
  core
  optional
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum Origin {
  seed
  agent
  user
  // Phase 2g: AI-generated content authored by us (the on-ramp orientation lesson),
  // not sourced from an external URL. Stored with synthetic `generated://…` urls and
  // the resource body in `Resource.content`.
  generated
}

enum SourceKind {
  official_docs
  educator
  course_platform
  textbook
  community
  // Phase 2g: the synthetic source for our own AI-generated content (the on-ramp
  // lesson). Deliberately NOT in the sourcing allowlist (loadAllowlistDomains), so a
  // generated:// row can never be discovered as a web candidate — it is only ever
  // attached directly by the generator.
  generated
}

enum ResourceStatus {
  active
  deprecated
  pending_review
}

// Severity of a pending-review rejection. `soft` — quality downgrade, future
// tracks only. `hard` — broken/dead link, may warrant patching in-flight
// learners once the Track layer exists.
enum DeprecationSeverity {
  soft
  hard
}

// Phase 2.5: lifecycle of a Resource w.r.t. container/atomic decomposition.
// `atomic` — a single, pickable unit (default; all pre-2.5 rows backfilled here).
// `decomposed` — a container whose children have been materialized; not pickable itself.
// `pending` — discovered as a container, decomposition deferred/in-flight; not pickable.
// `unsupported` — decomposer cannot handle this type (e.g. paywalled course); not pickable.
// `human_review` — needs manual curation before pickable.
enum DecompositionStatus {
  atomic
  decomposed
  pending
  unsupported
  human_review
}

// Phase 3a: User.id IS the Supabase auth user id (auth.users.id, a UUID string)
// — no separate authId column, so app tables join on the session id directly.
// Rows are written by a get-or-create sync on first authenticated request (3b),
// which is why there is no @default: the id always comes from Supabase.
// email/name/avatarUrl mirror the Google OAuth profile as of last sign-in.
// `role` is what withAdminAuth gates on (audit 9.1) — a real role, distinct
// from merely having a session. Paid status stays derived from Subscription.
model User {
  id             String            @id
  email          String            @unique
  name           String?
  avatarUrl      String?
  role           UserRole          @default(user)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  subscription   Subscription?
  enrollments    EnrolledProgram[]
  progress       Progress[]
  courseRequests CourseRequest[]
  programs       Program[]
  intakeSessions IntakeSession[]
}

enum UserRole {
  user
  admin
}

// Scaffold only — Phase 3 (Stripe) will extend with stripeCustomerId,
// stripeSubscriptionId, currentPeriodEnd, cancellation reasons, etc. `status`
// is a free-form string so we don't lock an enum before Stripe dictates the
// vocabulary. Splitting this from User now (rather than a `plan` column)
// acknowledges that billing concerns belong in their own aggregate.
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("inactive")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generation inputs live on Path (not EnrolledPath) because they shape the
// agent's content selection — prior knowledge gates which prereqs to skip,
// timeframe + hours/week trim optional items and bias toward shorter
// resources. Storing them here makes the path reproducible and the per-item
// rationale auditable ("why this fits a 6-week beginner at 4 hrs/week").
// Trade-off: less Path reuse across users with similar-but-different inputs;
// acceptable because (a) "no caching, same input = fresh path" is locked, and
// (b) dedup, if it becomes worthwhile, belongs at the agent layer.
// Phase 2.5c: Path is an input-agnostic concept map for a whole topic — one Path
// per canonical topic, hence @@unique([topic]). Phase 2.5g-7 retired the last of its
// user-specific columns (title/summary/difficulty/input*/createdById) together with
// PathItem: those moved to Track (the per-learner snapshot) at the cutover, so a Path
// is now purely { topic, status } + its concept-map relations.
model Path {
  id                   String         @id @default(cuid())
  topic                String
  // readiness gate. The map-builder authors the spine synchronously and flips the
  // Path to `spine_ready`; the first Track build is gated on it.
  // `draft` (pre-spine) → `building` (spine in flight) → `spine_ready` | `failed`.
  status               PathStatus     @default(draft)
  concepts             Concept[]
  tracks               Track[]
  remediationJobs      RemediationJob[]
  pathReviews          PathReview[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([topic])
}

// Phase 2.5c: Path readiness lifecycle for the spine-ready gate (see Path.status).
enum PathStatus {
  draft
  building
  spine_ready
  failed
}

// Phase 2.5g-7: PathItem (the old curriculum-record layer) + PathItemStatus retired
// at the cutover. Concept / ConceptPrereq / ConceptResource are the curriculum
// record now; Lesson / LessonResource / Exercise are the Track's delivery shape.

// Phase 3a: EnrolledPath (the inert 2.5c track-enrollment scaffold) retired,
// replaced by EnrolledProgram — Programs are the only user-facing artifact, so
// enrollment keys on the Program; Tracks are internal delivery structures
// reached through a Program.

// Phase 2.5c: progress re-keys from PathItem to Lesson — the Lesson is the
// completable unit in the Track delivery shape. Inert today (zero consumers), so
// the re-key is free. The table is empty, which is what makes the migration's
// `lessonId NOT NULL`-with-no-default safe — do NOT copy that onto a populated table.
model Progress {
  userId      String
  lessonId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@id([userId, lessonId])
  @@index([lessonId])
}

// Phase 2.5 — delivery structure built on top of a Path.
// 1:1 with Path today but kept as a separate aggregate: Path is the curriculum
// agent's selection record (what + why); Track is the post-processed, dedup'd
// delivery shape with generated content. Regenerable without re-running
// expensive library matching + web fallback.
//
// IMMUTABILITY: a Track is an immutable SNAPSHOT of its Path at build time, kept
// for future reference. Only the Path is maintained to stay accurate to current
// resource quality (so future Tracks are valid); a built Track is never patched
// when its Path or resources change. A Track may therefore point at a since-
// rejected/deprecated Resource — the row still exists, the snapshot still reads.
// Broken/stale Tracks are triaged manually (see the broken-tracks query page),
// not auto-healed. The reject pipeline reaches only the Path side (ConceptResource
// candidate-deprecation + readiness recompute), never live Tracks.
model Track {
  id        String      @id @default(cuid())
  // Phase 2.5c: dropped @unique — one Path (concept map) → many Tracks (learner
  // traversals). The per-learner inputs + user-facing title/summary that used to
  // live on Path move here; nullable for now since the builder (2.5e) populates
  // them and the table is empty.
  pathId    String
  path      Path        @relation(fields: [pathId], references: [id], onDelete: Cascade)
  status    TrackStatus @default(pending)
  priorKnowledge String?
  timeframeWeeks Int?
  hoursPerWeek   Int?
  // Phase 2.5e: the learner's target mastery for this Track. Reuses the
  // Difficulty enum so the Track composer can difficulty-match a concept's
  // primary resource against the target, and so `targetMastery` drives how deep
  // into the frontier the build reaches (advanced pulls more frontier than
  // beginner). Nullable like the other inert Track inputs; the builder defaults
  // null → beginner.
  targetMastery  Difficulty?
  // Phase 2.5e-6: `goal` is the learner's own free-text statement of why they're
  // taking this Track ("refresh calc before grad school", "drill for my exam");
  // `intent` is the coarse category the composer INFERS from that goal (+ prior
  // knowledge) in its one judgment pass and emits as structured output. We keep the
  // inferred label as a queryable column so deterministic downstream code (the
  // 2.5e-7 allocator) can branch on it and so intent is analyzable — the raw goal
  // is data, the enum is the decision. Both nullable like the other Track inputs;
  // the builder defaults a missing intent to `learn` (a fresh first pass).
  goal           String?
  intent         TrackIntent?
  title          String?
  summary        String?
  lessons     Lesson[]
  sections    Section[]
  courseRequests CourseRequest[]
  programPaths ProgramPath[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([pathId])
}

enum TrackStatus {
  pending
  building
  ready
  failed
}

// Phase 2.5e-6: why the learner is taking this Track, inferred by the composer
// from their free-text goal. Shapes pruning + (2.5e-7) time allocation:
//   learn     — fresh first pass; full depth, teach from first principles.
//   review    — refresh material they once knew; prune known spine readily, prefer
//               short refreshers + practice over long first-principles lectures.
//   practice  — drilling/application over new exposition; bias toward exercises.
//   master    — go deep / internalize beyond a first pass (depth of engagement;
//               orthogonal to targetMastery, which is the level ceiling of material).
//   exam_prep — time-boxed, breadth-first cram against an assessment.
enum TrackIntent {
  learn
  review
  practice
  master
  exam_prep
}

model Lesson {
  id              String           @id @default(cuid())
  trackId         String
  track           Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  orderInTrack    Int
  title           String
  summary         String
  conceptsTaught  String[]
  estMinutes      Int
  // Phase 2.5e (track sections): the chapter this lesson belongs to. Nullable so a
  // flat, un-sectioned Track is always valid — sectioning is a best-effort
  // post-build LLM pass (sectioner.ts), so a Track may render flat if it never ran,
  // failed, or was too short to section. SetNull (not Cascade): deleting a Section
  // ungroups its lessons rather than destroying them.
  sectionId       String?
  section         Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  resources       LessonResource[]
  exercises       Exercise[]
  progress        Progress[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([trackId, orderInTrack])
  @@index([sectionId])
}

// Phase 2.5e (track sections): a named chapter grouping a contiguous run of a
// Track's Lessons, with a short learner-facing intro. Built by the post-build
// sectioner (sectioner.ts / section-track.ts) — a separate LLM pass that groups
// the already-ordered, already-trimmed lessons, so a Section is always a
// contiguous run of `orderInTrack` and never references a budget-trimmed lesson.
// A Section is the "contentless chapter divider": it owns title + intro but holds
// no resources of its own, so the playground can render a header without
// fabricating a filler Lesson. Re-sectioning is idempotent (delete + recreate).
model Section {
  id           String   @id @default(cuid())
  trackId      String
  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  orderInTrack Int
  title        String
  intro        String?
  lessons      Lesson[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // No separate @@index([trackId]): the composite unique above already provides a
  // trackId left-prefix index for the sectioner/renderer's trackId-only lookups.
  @@unique([trackId, orderInTrack])
}

// Join row between a Lesson and a Resource. `role` distinguishes the canonical
// resource from alternates surfaced via cross-resource concept dedup.
// `deliveryMode` is per-resource-in-this-context (a single Lesson may mix an
// embeddable video, a new-tab article, and a native exercise). `segmentRef`
// carries YouTube timestamps / doc anchors when only part of a resource is used.
model LessonResource {
  id           String             @id @default(cuid())
  lessonId     String
  lesson       Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  resourceId   String
  resource     Resource           @relation(fields: [resourceId], references: [id])
  role         LessonResourceRole @default(primary)
  // Phase 2.5e-7b: render/selection order WITHIN a lesson. The allocator emits a
  // ranked list — the mandatory complementary core (multiple role=primary rows) in
  // priority order, then the optional/alternate substitute pool. One sequence per
  // lesson (primaries 1..k first, then alternates); `role` distinguishes core vs
  // optional. @default(0) covers pre-2.5e-7b rows; the builder always sets it.
  orderInLesson Int               @default(0)
  deliveryMode DeliveryMode
  segmentRef   Json?
  createdAt    DateTime           @default(now())

  @@unique([lessonId, resourceId])
  @@index([lessonId])
  @@index([resourceId])
}

enum LessonResourceRole {
  primary
  alternate
}

enum DeliveryMode {
  embed
  newtab
  native
}

// Agent-generated practice attached to a Lesson. `kind` is intentionally narrow
// for 2.5e (text/MCQ); broaden when later kinds (code, etc.) ship.
model Exercise {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  prompt    String
  answer    String
  rubric    String
  kind      ExerciseKind
  origin    Origin       @default(agent)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([lessonId])
}

enum ExerciseKind {
  text
  mcq
}

// Phase 2.5c — Topic Concept Map. A Concept is a Path-scoped node in the topic's
// prerequisite DAG. Canonicalization is a within-one-map match-or-create on the
// per-Path `slug` (never global — see ROADMAP "Why Path-scoped"). `membership`
// splits the required backbone (`spine`, gates the first Track) from opt-in
// enrichment (`frontier`, thickened async).
model Concept {
  id         String            @id @default(cuid())
  pathId     String
  path       Path              @relation(fields: [pathId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  membership ConceptMembership @default(spine)
  // Phase 2.5 (on-ramp magnet fix): marks the single orientation "on-ramp" concept
  // the spine author opens every map with (what the subject is, core mental model,
  // setup/first steps). It is deliberately BROAD — the one concept exempt from the
  // "one idea per concept" rule — which makes it a semantic magnet: a generic title
  // ("Introduction to Calculus") searched against a single-subject corpus pulls in
  // the whole subject, and the per-concept judge (no map context) scores deep-dive
  // resources high for it. This flag lets candidate attachment/sourcing source it
  // with a discriminating query + a strict "orientation-only" judge rubric. Exactly
  // one spine concept per Path carries it; split/frontier concepts never do.
  isOnRamp   Boolean           @default(false)
  // Phase 2.5f: set when remediation, unable to source a `teaches` candidate at
  // or above MAP_SPINE_MIN_PRIMARY_COVERAGE, accepts the best available sub-floor
  // primary so the learner still gets a (weaker) course. Readiness (2.5f-3) treats
  // a relaxed concept with any candidate as covered, not a spine hole. Column only
  // this block; the readiness honoring + the writer land in 2.5f-3.
  primaryRelaxed Boolean        @default(false)
  // Phase 2.5h: cleared (false) while a concept's question bank is still only the
  // initial agent-generated set; flipped true once an operator has reviewed/curated
  // it (via the discovery API). Drives the "weak banks, oldest first" worklist —
  // it's an explicit review flag, deliberately decoupled from `origin`/question count
  // so "I checked this" is distinct from "a human-authored question exists".
  bankReviewed Boolean          @default(false)
  // Phase 2.5i: non-null marks a *reviewed* bank whose grounding resources have since
  // changed, so it rejoins the discovery worklist (route.ts) for manual re-curation —
  // the existing questions are left untouched; an operator edits them by hand and
  // clears this by re-marking the bank reviewed. Set ONLY for already-reviewed concepts
  // (bankReviewed=true) by markBankStale (mark-bank-stale.ts); unreviewed concepts are
  // already on the worklist. The value is the change kind, for triage. ⚠️ Any code that
  // adds/removes this concept's ConceptResource rows should consider calling
  // markBankStale — see the note in mark-bank-stale.ts.
  bankStaleReason BankStaleReason?
  // Prereq edges in both directions: `prereqsOut` are edges where this concept
  // is the prerequisite; `prereqsIn` are edges where it is the dependent.
  prereqsOut ConceptPrereq[]   @relation("PrereqFrom")
  prereqsIn  ConceptPrereq[]   @relation("PrereqTo")
  resources  ConceptResource[]
  questions  ConceptQuestion[]
  sourcedResources ResourceSourcedFor[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([pathId, slug])
  @@index([pathId, membership])
}

enum ConceptMembership {
  spine
  frontier
}

// Phase 2.5i — why a reviewed Concept's question bank went stale (its grounding
// resources changed). Drives triage on the discovery worklist: `primary_changed`
// (a `teaches`-role candidate attached/removed — the main material shifted) ranks
// above `resource_removed` (a non-`teaches` candidate removed). Narrowed on purpose:
// attaching a non-`teaches` (supplementary) candidate does NOT flag, since it can't
// invalidate an existing question. See markBankStale in mark-bank-stale.ts.
enum BankStaleReason {
  primary_changed
  resource_removed
}

// Phase 2.5c — a directed prerequisite edge within one Path's concept DAG.
// `from → to` reads "learn `from` before `to`": `from` is the prerequisite, `to`
// depends on it. `pathId` is denormalized so the Track builder can load the whole
// map's edges in one indexed query (and as an integrity anchor that every edge
// stays intra-Path). Cycle-freeness is a DAG invariant the builder validates at
// write; the DB enforces only no-duplicate-edges and (via migration CHECK) no
// self-loop.
model ConceptPrereq {
  id            String  @id @default(cuid())
  pathId        String
  fromConceptId String
  toConceptId   String
  from          Concept @relation("PrereqFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  to            Concept @relation("PrereqTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([fromConceptId, toConceptId])
  @@index([toConceptId])
  @@index([pathId])
}

// Phase 2.5c — candidate link between a Concept and a pickable Resource. `role`
// distinguishes how the resource serves the concept (a Resource serves exactly
// one purpose, hence one role per pair — @@unique([conceptId, resourceId])).
// `coverageScore` ranks candidates so the Track builder picks a `primary` greedily
// and freezes the rest as `alternate` LessonResources. The resourceId index backs
// the 2.5f reject-pipeline reach-in (find concepts depending on a deprecated row).
// ⚠️ Phase 2.5i: adding/removing rows here can stale a reviewed Concept's question
// bank — consider calling markBankStale (src/lib/agents/content/mark-bank-stale.ts);
// see the call-site note there for which mutations flag and why.
model ConceptResource {
  id            String              @id @default(cuid())
  conceptId     String
  concept       Concept             @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      Resource            @relation(fields: [resourceId], references: [id])
  role          ConceptResourceRole @default(teaches)
  coverageScore Float
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([conceptId, resourceId])
  @@index([conceptId])
  @@index([resourceId])
}

enum ConceptResourceRole {
  teaches
  uses
  assesses
}

// Library re-judge Block 1 — sourcing provenance. Records every Concept whose
// remediation/thickener demand caused a resource to be sourced but NOT attached
// in the same run (the row parked non-atomic: pending / human_review /
// unsupported / decomposed container). Written in web-fallback's persistence
// tail on BOTH the insert and the dedup-rediscovery path (skipDuplicates makes
// a re-demand under a second concept a second pair, not an error). Atomic rows
// are judged+attached in-run and never recorded here. Consumed by the
// decompose-time hook (Block 3), which resolves surviving pairs to their paths
// and judges the decomposed children against those paths' concepts. Cascades
// with both parents, so a deleted Concept (or Resource) leaves no dangling
// demand and the hook's zero-pairs case is a clean no-op.
model ResourceSourcedFor {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  conceptId  String
  concept    Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([resourceId, conceptId])
  @@index([conceptId])
}

// Phase 2.5h — a question in a Concept's reusable question bank. Generated ONCE
// per concept (a small agent-authored set, near spine-readiness), then sampled at
// Track build into per-Lesson `Exercise` snapshots — so the expensive authoring is
// amortized across every Track built off the Path, and build-time is cheap
// selection. Path-scoped via the Concept (never global). `origin` is provenance:
// `agent` for the generated seed set, `user` for operator-authored questions added
// through the discovery API. MCQ options are embedded in `prompt` (no options
// column — the renderer is reveal-only until the Phase-4 tutor). Cascade: questions
// die with the concept.
model ConceptQuestion {
  id        String       @id @default(cuid())
  conceptId String
  concept   Concept      @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  prompt    String
  answer    String
  rubric    String
  kind      ExerciseKind
  origin    Origin       @default(agent)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([conceptId])
}

// Phase 2.5f — the durable record + single-flight claim for one spine-hole
// remediation pass over a Path. A `building` Path (or a hard-deprecation
// regression) gets ONE active job; concurrent claims are blocked by a PARTIAL
// unique index on (pathId) WHERE state IN ('queued','running') — Prisma can't
// express partial indexes, so that index is created in raw SQL in the migration
// (NOT here). Terminal rows (succeeded/failed/escalated) accumulate as an audit
// trail and don't block a future re-claim. The async poller + request-path
// enqueue that drive this automatically are 2.5g; this block invokes it manually.
model RemediationJob {
  id     String           @id @default(cuid())
  pathId String
  path   Path             @relation(fields: [pathId], references: [id], onDelete: Cascade)
  state  RemediationState @default(queued)
  // Set when state→running; the basis for stale-claim reclaim (a job whose worker
  // died mid-run), which the 2.5g poller acts on. The manual driver uses --force.
  claimedAt             DateTime?
  // The spine-hole slugs this job set out to fix (snapshot at claim time).
  holeSlugs             String[]
  // Concepts where remediation accepted a sub-floor best-effort primary (relaxed
  // the bar) so the Path could still reach spine_ready.
  relaxedConceptSlugs   String[]  @default([])
  // Concepts left uncoverable even after sourcing — parked in the review queue and
  // (2.5g) paged. The Path stays `building`; the job lands `escalated`.
  escalatedConceptSlugs String[]  @default([])
  // Failure diagnostic when state=failed (an unexpected error, not an escalation).
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([pathId])
}

enum RemediationState {
  queued
  running
  succeeded
  failed
  // Finished, but ≥1 concept was left uncoverable (Path remains `building`).
  escalated
}

// Pre-Freeze Map Review (Block 1): the operator worklist row for a finding the
// whole-map, resource-aware critic raised at the `building → spine_ready` freeze
// boundary — the review reviewSpine structurally can't do (it runs pre-frontier,
// pre-split, pre-resource). Findings NEVER block the freeze; the Path still goes
// `spine_ready` and these are hardened in place later. One row per finding,
// per-(path, concept(s), kind), because a finding targets specific concepts and
// carries a resolution state no existing flag column models.
//
// `conceptSlugs` is denormalized (NOT an FK to Concept) on purpose: a later merge
// DELETEs the loser concept, but the finding that named it must survive so the
// operator record stays intact — same snapshot-by-slug philosophy as splitConcept.
// The writer replaces the OPEN (resolved=false) rows on each run and leaves
// resolved rows untouched, so a backfill re-review is idempotent and never
// clobbers an operator's decision. `resolution` is null until Block 3 decides it.
model PathReview {
  id           String                @id @default(cuid())
  pathId       String
  path         Path                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  kind         MapReviewKind
  // The concept slug(s) the finding implicates: two for a `duplication`, one for a
  // `hollow` / `granularity`. Denormalized (see model note).
  conceptSlugs String[]
  // What's wrong and the concrete fix — the operator (or Block 3's apply) acts on it.
  message      String
  resolved     Boolean               @default(false)
  // Set when an operator decides the finding (Block 3); null while open.
  resolution   PathReviewResolution?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([pathId, resolved])
}

// The map-review finding kinds — only what the spine-only critic structurally
// cannot produce (see review-map.ts). `granularity` overlaps the spine reviewer's
// kind by name but is re-run here over remediation split-in nodes it never saw.
enum MapReviewKind {
  // Two concepts cover the same idea (post-frontier/post-split redundancy, e.g.
  // sql-views vs database-views). Merge target is the primary fix.
  duplication
  // A concept "covered" only by a relaxed or low-coverage primary — a papered-over
  // hole. Deterministic (a coverage threshold), not an LLM judgment.
  hollow
  // A split-in / assembled node that bundles several teachable ideas — the spine
  // reviewer's granularity check, re-run over nodes added after it ran.
  granularity
}

// How an operator resolved a PathReview finding (Block 3). Null while open.
enum PathReviewResolution {
  // The duplicate was merged into its winner (loser's edges/resources repointed).
  merged
  // Not a real problem — dismissed without a mutation.
  dismissed
  // A real finding intentionally left as-is for now (acknowledged, no fix).
  kept
}

// Phase 2.5g-1: a learner's request for a Track on a topic — the durable unit the
// fire-and-forget route enqueues and the out-of-band worker drains. The route only
// validates the topic + inserts a `queued` row and acks; the worker claims it,
// runs ensurePathMap → remediate → buildTrack, then records the result here (the
// hook for the eventual "course ready" notification, Phase 3).
//
// Deliberately NOT single-flighted (no partial unique index like RemediationJob):
// each learner request is its own row → its own Track (per-learner snapshots). The
// expensive work is deduped one layer down — ensurePathMap's advisory lock + the
// RemediationJob active-per-path index — so two requests for the same building
// topic serialize there, not here.
model CourseRequest {
  id             String              @id @default(cuid())
  // Canonical topic slug (post topic-gate). NOT an FK to Path: the Path may not
  // exist yet at enqueue time — the worker get-or-creates it (ensurePathMap).
  topic          String
  // Per-learner Track inputs, carried so the worker can build the Track once the
  // Path reaches spine_ready. Mirror Track's nullable input columns. userId is
  // null until Phase 3 auth wires a real session (mirrors the retiring
  // Path.createdById); SetNull keeps the request if the User is later removed.
  userId         String?
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Phase 2.75a: set when this request is a child of a Program's plan pass (null
  // for a standalone /generate-path request). The per-topic build path is
  // unchanged; the worker's post-fulfill assembler hook keys on this to finalize
  // the Program once all siblings are terminal. Cascade: deleting a Program kills
  // its orphan child-builds (unlike userId, the Program is the reason the request
  // exists), and the @@index serves the "all siblings for this programId" query.
  programId      String?
  program        Program?            @relation(fields: [programId], references: [id], onDelete: Cascade)
  priorKnowledge String?
  goal           String?
  timeframeWeeks Int?
  hoursPerWeek   Int?
  targetMastery  Difficulty?
  // Decomposer-agent plan: free-text frontier-concept requests ("reinforcement
  // learning") the worker executes via addFrontierConcept once the Path is
  // spine_ready, before buildTrack. On CourseRequest (not ProgramPath) so the
  // hook serves ANY request source; capped by MAX_FRONTIER_PER_TOPIC in the
  // worker. Empty for every request until the decompose-agent populates it.
  frontierConcepts String[]           @default([])
  status         CourseRequestStatus @default(queued)
  // Set when status→running (worker claim); the basis for stale-claim reclaim by
  // age (a worker that died mid-run), which the g-3 worker acts on each tick.
  claimedAt      DateTime?
  // Workers-A1 (D3): claims consumed. Incremented at claim time ONLY (the single
  // code path) — contention requeues and stale reclaims each burn one attempt on
  // re-claim. requeueCourseRequest/reclaimStale fail the row terminally once this
  // reaches COURSE_REQUEST_MAX_ATTEMPTS (poison-request cap, D5).
  attempts       Int                 @default(0)
  // Workers-A1 (D2/D10): earliest next claim; null = immediately claimable. Set by
  // requeueCourseRequest (contention backoff); cleared on stale reclaim (a dead
  // worker's request retries immediately). Claim ordering stays createdAt ASC — a
  // requeued row rejoins at its original priority once eligible.
  nextAttemptAt  DateTime?
  // Workers-A1 (D6): worker identity (hostname / Cloud Run instance id) stamped at
  // claim. Observability only. Deliberately NOT cleared on requeue/reclaim: a
  // bounced row keeps its last claimant for stale-claim triage.
  claimedBy      String?
  // The built Track on success; null until fulfilled. SetNull keeps the request
  // row for audit if the (immutable) Track is later deleted in cleanup.
  trackId        String?
  track          Track?              @relation(fields: [trackId], references: [id], onDelete: SetNull)
  // Failure diagnostic when status=failed.
  error          String?
  // H3 (audit 9.4): per-build token usage, written by the worker at finish —
  // a UsageSnapshot ({ stages, totals }, see src/lib/log.ts). Null = not
  // measured (pre-H3 rows, or a build whose trace recorded nothing).
  buildUsage     Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Serves the claim query: status='queued' ORDER BY createdAt asc.
  @@index([status, createdAt])
  // Phase 2.75a: serves the assembler's "all siblings for this programId" scan.
  @@index([programId])
}

enum CourseRequestStatus {
  queued
  running
  fulfilled
  failed
}

// Phase 2.75a: a goal-driven, multi-topic plan — the headline differentiator ("a
// plan that gets you to your goal", not "a course"). A Program owns N single-topic
// Tracks via ProgramPath. It rides the EXISTING CourseRequest queue: a synchronous
// plan pass (the program agent, 2.75b) decomposes the goal into gated topics +
// budgets + order, enqueueProgram (2.75c) fans those out as child CourseRequests
// (programId set), and the worker's post-fulfill assembler finalizes the Program
// when all children are terminal. The per-topic build path is unchanged.
model Program {
  id                String          @id @default(cuid())
  // The learner's free-text goal ("ready for NUS Sem 1 CS AI by Aug 2026").
  goal              String
  // Program-level analog of a Track's priorKnowledge; nullable like it.
  background        String?
  // Phase 3a: the shareable display surface, generated by the plan pass (3c) —
  // neutral and non-personal ("Calculus foundations for engineering coursework").
  // goal/background above are creator-PRIVATE: never rendered to non-creators;
  // anyone else sees only title/description + the phased plan. Nullable because
  // pre-3c rows (and failed plan passes) predate the generation step.
  title             String?
  description       String?
  // Total weekly budget + horizon. NOT NULL (unlike Track's inert inputs): the
  // deterministic budget split is meaningless without them and this is greenfield.
  // v1 (parallel builds): every child Track spans totalWeeks; totalHoursPerWeek is
  // split across topics by LLM weight (floor 1 h/wk).
  totalHoursPerWeek Int
  totalWeeks        Int
  // Decomposition prompt constraint (topic-level exclusion), NOT a resource filter.
  // Stored for audit + re-run reproducibility.
  antiList          String[]        @default([])
  // planning → building → ready | partial | failed. `planning` is the pre-plan
  // anchor enqueueProgram writes before the fallible plan pass, so a failed plan
  // leaves an auditable row; `partial` = some child Tracks built, some failed.
  status            ProgramStatus   @default(planning)
  // Failure diagnostic when status=failed (plan pass produced nothing or threw).
  // Mirrors CourseRequest.error / RemediationJob.error.
  error             String?
  // H3 (audit 9.4): the plan pass's token usage (decompose + gate + reconcile),
  // written by enqueueProgram — a UsageSnapshot ({ stages, totals }, see
  // src/lib/log.ts). Null = not measured (pre-H3 rows / untraced callers).
  planUsage         Json?
  // Null until Phase 3 auth wires a real session (mirrors CourseRequest.userId).
  // SetNull keeps the Program if the User is later removed.
  userId            String?
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  // H1 (audit 1.1): sha256 fingerprint of the normalized creation payload
  // (programInputHash) — the idempotency key findRecentDuplicate matches a
  // resubmit against. Null for pre-H1 rows and unmetered (dev/operator) creations.
  inputHash         String?
  programPaths      ProgramPath[]
  courseRequests    CourseRequest[]
  enrollments       EnrolledProgram[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Serves the per-user metering scans (programQuota month count, programBurst
  // hour count, findRecentDuplicate window lookup) — all filter on userId +
  // createdAt first.
  @@index([userId, createdAt])
}

// Phase 3a: program enrollment — the user-facing access record. Programs are
// the only user-facing artifact (Tracks are internal, reached through a
// Program), so enrollment keys on the Program. Creation is metered (free
// monthly cap, enforced at enqueue in 3c); enrollment is free and unlimited —
// the creator is auto-enrolled in the same transaction that creates the
// Program, and other users may enroll in an existing Program without burning
// quota. Replaces the retired EnrolledPath scaffold.
model EnrolledProgram {
  userId     String
  programId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@id([userId, programId])
  @@index([programId])
}

// Phase 2.75a: the Program ↔ Track join, carrying the plan pass's presentation
// metadata (phase grouping, cross-program order, priority tier). Design B: rows are
// created at PLAN time (so the plan is DB-inspectable the instant the synchronous
// pass returns, before any build finishes) keyed by canonical `topic`; the worker's
// assembler fills in `trackId` once the child build fulfills. A null `trackId`
// therefore means "planned but not yet built" — or, in a `partial` Program, a topic
// whose build failed (its plan slot stays visible).
model ProgramPath {
  id             String       @id @default(cuid())
  programId      String
  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  // Canonical topic slug (post topic-gate) — the correlation key the assembler uses
  // to match a fulfilled child CourseRequest (same programId + topic) to its slot.
  topic          String
  // Nullable until assembly; SetNull (not Cascade) so deleting an immutable Track in
  // cleanup leaves the plan slot intact, consistent with CourseRequest.trackId.
  trackId        String?
  track          Track?       @relation(fields: [trackId], references: [id], onDelete: SetNull)
  // Presentation grouping ("Month 1: math + PyTorch") and cross-program order,
  // LLM-inferred at plan time. v1 is presentation-only — child Tracks build in
  // parallel; the order drives display, not the build.
  phaseLabel     String
  orderInProgram Int
  priorityTier   PriorityTier
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // One slot per canonical topic per Program (defensively enforces the plan pass's
  // post-canonicalization topic dedup); stable, gap-free display order per Program.
  @@unique([programId, topic])
  @@unique([programId, orderInProgram])
  @@index([trackId])
}

enum ProgramStatus {
  planning
  building
  ready
  partial
  failed
}

enum PriorityTier {
  core
  nice_to_have
}

// Chat intake (Block 1): one row per intake conversation — the rate-limit anchor
// (sessions-per-hour count over [userId, createdAt]) and the server-authoritative
// draft/turn state. Deliberately minimal and PERMANENT in shape: no message or
// transcript storage, ever (user decision — the transcript is client-held and
// resent each turn as conversational context only).
model IntakeSession {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  status    IntakeSessionStatus @default(active)
  // Server-side turn counter — the INTAKE_MAX_TURNS budget anchor. A tampered
  // client transcript can't dodge it because only the route increments it.
  turnCount Int                 @default(0)
  // Partial GenerateProgramInput, server-authoritative — each turn the route
  // loads THIS draft (never the client's), merges the agent's extraction, and
  // persists the result. Ready = it parses against generateProgramInputSchema.
  draft     Json?
  // Accumulated per-turn token usage (H3 idiom — a UsageSnapshot, mirrors
  // Program.planUsage) so intake LLM spend is visible per session.
  usage     Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  // The sessions-per-hour burst count (intakeSessionBurst).
  @@index([userId, createdAt])
}

// `submitted`/`abandoned` are reserved for later write-backs (funnel metrics);
// Blocks 1–4 only transition active → exhausted. Enum minted now so the column
// never needs a migration when those land.
enum IntakeSessionStatus {
  active
  submitted
  exhausted
  abandoned
}
