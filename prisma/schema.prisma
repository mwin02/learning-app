// Prisma schema for the Adaptive Learning Path app.
// Prisma 7 moved connection URLs out of schema.prisma into prisma.config.ts.
// Runtime DB connection is set up in src/lib/db.ts via @prisma/adapter-pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  topic                String
  title                String
  url                  String         @unique
  type                 ResourceType
  tier                 ResourceTier   @default(core)
  durationMin          Int
  summary              String
  difficulty           Difficulty
  prerequisiteConcepts String[]
  conceptsTaught       String[]
  requiresPurchase     Boolean        @default(false)
  origin               Origin         @default(seed)
  status               ResourceStatus @default(active)
  // Set when a pending-review reject deprecates the row. `soft` = quality
  // downgrade (future tracks only); `hard` = broken/dead link (a future Track
  // layer may need to patch or flag in-flight learners). Null for rows that
  // were never rejected. See src/lib/curation/pending-review.ts.
  deprecationSeverity  DeprecationSeverity?
  language             String         @default("en")
  trustScore           Float          @default(0.5)
  attribution          String?
  sourceId             String
  source               Source         @relation(fields: [sourceId], references: [id])
  // Phase 2.5: container/atomic decomposition. This is a tree of arbitrary
  // depth: a container (decompositionStatus='decomposed') holds children, and a
  // child may itself be a 'decomposed' container (a path → its courses → their
  // lessons). Only leaves are 'atomic'. The root has a null parent; every other
  // node has a non-null parent. "Pickable" by the curriculum agent is DERIVED:
  // status='active' AND decompositionStatus='atomic' — i.e. any 'decomposed'
  // container (root OR intermediate) is not pickable, only its atomic leaves are.
  // Do not add a pickable column.
  parentResourceId     String?
  parent               Resource?      @relation("ResourceDecomposition", fields: [parentResourceId], references: [id], onDelete: SetNull)
  children             Resource[]     @relation("ResourceDecomposition")
  orderInParent        Int?
  decompositionStatus  DecompositionStatus @default(atomic)
  // Phase 2.5-AR: semantic search. `embedding` is a pgvector column (text-
  // embedding-005, 768 dims) over `title + summary + conceptsTaught`. Typed
  // Unsupported because Prisma has no native vector type — it is written and
  // queried only via raw SQL in src/lib/embeddings.ts, never through the
  // client. `embeddedAt` is the staleness signal: backfill re-embeds rows
  // where it is null or older than `updatedAt`. The hnsw index lives in the
  // migration SQL (Prisma can't express it). See ROADMAP Phase 2.5-AR.
  embedding            Unsupported("vector(768)")?
  embeddedAt           DateTime?
  pathItems            PathItem[]
  lessonResources      LessonResource[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([topic, status, tier])
  @@index([difficulty])
  @@index([sourceId])
  @@index([parentResourceId])
  @@unique([parentResourceId, orderInParent])
}

// Phase 2.5-AR (AR-5): persisted topic canonicalization registry. The topic
// gate's LLM tier mints a canonical slug for off-library topics; without memory
// it could map "go" one run and "golang" the next, partitioning the Resource
// library (which keys on an exact `topic` match). Each row records a normalized
// input phrasing (`alias`) → the canonical slug it resolved to. A repeat
// phrasing short-circuits the LLM; the distinct set of `canonical` values (plus
// the curated TOPIC_SLUGS) is the vocabulary the gate grounds the LLM on so new
// phrasings collapse onto existing slugs. Curated slugs are NOT seeded here —
// they short-circuit earlier and remain code-owned in src/types/resource.ts.
model TopicAlias {
  id        String   @id @default(cuid())
  alias     String   @unique
  canonical String
  subject   String
  createdAt DateTime @default(now())

  @@index([canonical])
}

model Source {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  url        String
  kind       SourceKind
  trustScore Float      @default(0.5)
  resources  Resource[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([kind])
}

enum ResourceType {
  article
  video
  course
  interactive
  docs
  book
}

enum ResourceTier {
  core
  optional
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum Origin {
  seed
  agent
  user
}

enum SourceKind {
  official_docs
  educator
  course_platform
  textbook
  community
}

enum ResourceStatus {
  active
  deprecated
  pending_review
}

// Severity of a pending-review rejection. `soft` — quality downgrade, future
// tracks only. `hard` — broken/dead link, may warrant patching in-flight
// learners once the Track layer exists.
enum DeprecationSeverity {
  soft
  hard
}

// Phase 2.5: lifecycle of a Resource w.r.t. container/atomic decomposition.
// `atomic` — a single, pickable unit (default; all pre-2.5 rows backfilled here).
// `decomposed` — a container whose children have been materialized; not pickable itself.
// `pending` — discovered as a container, decomposition deferred/in-flight; not pickable.
// `unsupported` — decomposer cannot handle this type (e.g. paywalled course); not pickable.
// `human_review` — needs manual curation before pickable.
enum DecompositionStatus {
  atomic
  decomposed
  pending
  unsupported
  human_review
}

// Phase 2 keeps User minimal. Auth fields (email, supabaseId, etc.) land in
// Phase 3 with Supabase Google OAuth. Paid status is derived from Subscription.
model User {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscription  Subscription?
  createdPaths  Path[]
  enrollments   EnrolledPath[]
  progress      Progress[]
}

// Scaffold only — Phase 3 (Stripe) will extend with stripeCustomerId,
// stripeSubscriptionId, currentPeriodEnd, cancellation reasons, etc. `status`
// is a free-form string so we don't lock an enum before Stripe dictates the
// vocabulary. Splitting this from User now (rather than a `plan` column)
// acknowledges that billing concerns belong in their own aggregate.
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("inactive")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generation inputs live on Path (not EnrolledPath) because they shape the
// agent's content selection — prior knowledge gates which prereqs to skip,
// timeframe + hours/week trim optional items and bias toward shorter
// resources. Storing them here makes the path reproducible and the per-item
// rationale auditable ("why this fits a 6-week beginner at 4 hrs/week").
// Trade-off: less Path reuse across users with similar-but-different inputs;
// acceptable because (a) "no caching, same input = fresh path" is locked, and
// (b) dedup, if it becomes worthwhile, belongs at the agent layer.
model Path {
  id                   String         @id @default(cuid())
  topic                String
  title                String
  summary              String
  difficulty           Difficulty
  inputPriorKnowledge  String?
  inputTimeframeWeeks  Int?
  inputHoursPerWeek    Int?
  createdById          String?
  createdBy            User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items                PathItem[]
  track                Track?
  enrollments          EnrolledPath[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([topic])
  @@index([createdById])
}

model PathItem {
  id            String         @id @default(cuid())
  pathId        String
  path          Path           @relation(fields: [pathId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      Resource       @relation(fields: [resourceId], references: [id])
  order         Int
  rationale     String
  status        PathItemStatus @default(active)
  // Phase-5 scaffolding — created here per the locked plan but inert until
  // the adaptive-branch feature lands. `branchOnFail` is a plain nullable
  // string (not an FK) so Phase 5 can decide whether it points to a
  // PathItem id, a Resource id, or something else without a migration.
  isCheckpoint  Boolean        @default(false)
  branchOnFail  String?
  progress      Progress[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([pathId, order])
  @@index([resourceId])
}

enum PathItemStatus {
  active
  removed
}

model EnrolledPath {
  userId     String
  pathId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  path       Path     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@id([userId, pathId])
  @@index([pathId])
}

model Progress {
  userId      String
  pathItemId  String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathItem    PathItem @relation(fields: [pathItemId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@id([userId, pathItemId])
  @@index([pathItemId])
}

// Phase 2.5 — delivery structure built on top of a Path.
// 1:1 with Path today but kept as a separate aggregate: Path is the curriculum
// agent's selection record (what + why); Track is the post-processed, dedup'd
// delivery shape with generated content. Regenerable without re-running
// expensive library matching + web fallback.
model Track {
  id        String      @id @default(cuid())
  pathId    String      @unique
  path      Path        @relation(fields: [pathId], references: [id], onDelete: Cascade)
  status    TrackStatus @default(pending)
  lessons   Lesson[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum TrackStatus {
  pending
  building
  ready
  failed
}

model Lesson {
  id              String           @id @default(cuid())
  trackId         String
  track           Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  orderInTrack    Int
  title           String
  summary         String
  conceptsTaught  String[]
  estMinutes      Int
  resources       LessonResource[]
  exercises       Exercise[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([trackId, orderInTrack])
}

// Join row between a Lesson and a Resource. `role` distinguishes the canonical
// resource from alternates surfaced via cross-resource concept dedup.
// `deliveryMode` is per-resource-in-this-context (a single Lesson may mix an
// embeddable video, a new-tab article, and a native exercise). `segmentRef`
// carries YouTube timestamps / doc anchors when only part of a resource is used.
model LessonResource {
  id           String             @id @default(cuid())
  lessonId     String
  lesson       Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  resourceId   String
  resource     Resource           @relation(fields: [resourceId], references: [id])
  role         LessonResourceRole @default(primary)
  deliveryMode DeliveryMode
  segmentRef   Json?
  createdAt    DateTime           @default(now())

  @@unique([lessonId, resourceId])
  @@index([lessonId])
  @@index([resourceId])
}

enum LessonResourceRole {
  primary
  alternate
}

enum DeliveryMode {
  embed
  newtab
  native
}

// Agent-generated practice attached to a Lesson. `kind` is intentionally narrow
// for 2.5e (text/MCQ); broaden when later kinds (code, etc.) ship.
model Exercise {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  prompt    String
  answer    String
  rubric    String
  kind      ExerciseKind
  origin    Origin       @default(agent)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([lessonId])
}

enum ExerciseKind {
  text
  mcq
}
