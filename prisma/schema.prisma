// Prisma schema for the Adaptive Learning Path app.
// Prisma 7 moved connection URLs out of schema.prisma into prisma.config.ts.
// Runtime DB connection is set up in src/lib/db.ts via @prisma/adapter-pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Resource {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  topic                String
  title                String
  url                  String         @unique
  type                 ResourceType
  tier                 ResourceTier   @default(core)
  durationMin          Int
  summary              String
  difficulty           Difficulty
  prerequisiteConcepts String[]
  conceptsTaught       String[]
  requiresPurchase     Boolean        @default(false)
  origin               Origin         @default(seed)
  status               ResourceStatus @default(active)
  // Set when a pending-review reject deprecates the row. `soft` = quality
  // downgrade (future tracks only); `hard` = broken/dead link (a future Track
  // layer may need to patch or flag in-flight learners). Null for rows that
  // were never rejected. See src/lib/curation/pending-review.ts.
  deprecationSeverity  DeprecationSeverity?
  language             String         @default("en")
  trustScore           Float          @default(0.5)
  attribution          String?
  sourceId             String
  source               Source         @relation(fields: [sourceId], references: [id])
  // Phase 2.5: container/atomic decomposition. This is a tree of arbitrary
  // depth: a container (decompositionStatus='decomposed') holds children, and a
  // child may itself be a 'decomposed' container (a path → its courses → their
  // lessons). Only leaves are 'atomic'. The root has a null parent; every other
  // node has a non-null parent. "Pickable" by the curriculum agent is DERIVED:
  // status='active' AND decompositionStatus='atomic' — i.e. any 'decomposed'
  // container (root OR intermediate) is not pickable, only its atomic leaves are.
  // Do not add a pickable column.
  parentResourceId     String?
  parent               Resource?      @relation("ResourceDecomposition", fields: [parentResourceId], references: [id], onDelete: SetNull)
  children             Resource[]     @relation("ResourceDecomposition")
  orderInParent        Int?
  decompositionStatus  DecompositionStatus @default(atomic)
  // Phase 2.5-AR: semantic search. `embedding` is a pgvector column (text-
  // embedding-005, 768 dims) over `title + summary + conceptsTaught`. Typed
  // Unsupported because Prisma has no native vector type — it is written and
  // queried only via raw SQL in src/lib/embeddings.ts, never through the
  // client. `embeddedAt` is the staleness signal: backfill re-embeds rows
  // where it is null or older than `updatedAt`. The hnsw index lives in the
  // migration SQL (Prisma can't express it). See ROADMAP Phase 2.5-AR.
  embedding            Unsupported("vector(768)")?
  embeddedAt           DateTime?
  pathItems            PathItem[]
  lessonResources      LessonResource[]
  conceptResources     ConceptResource[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([topic, status, tier])
  @@index([difficulty])
  @@index([sourceId])
  @@index([parentResourceId])
  @@unique([parentResourceId, orderInParent])
}

// Phase 2.5-AR (AR-5): persisted topic canonicalization registry. The topic
// gate's LLM tier mints a canonical slug for off-library topics; without memory
// it could map "go" one run and "golang" the next, partitioning the Resource
// library (which keys on an exact `topic` match). Each row records a normalized
// input phrasing (`alias`) → the canonical slug it resolved to. A repeat
// phrasing short-circuits the LLM; the distinct set of `canonical` values (plus
// the curated TOPIC_SLUGS) is the vocabulary the gate grounds the LLM on so new
// phrasings collapse onto existing slugs. Curated slugs are NOT seeded here —
// they short-circuit earlier and remain code-owned in src/types/resource.ts.
model TopicAlias {
  id        String   @id @default(cuid())
  alias     String   @unique
  canonical String
  subject   String
  createdAt DateTime @default(now())

  @@index([canonical])
}

model Source {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  url        String
  kind       SourceKind
  trustScore Float      @default(0.5)
  resources  Resource[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([kind])
}

enum ResourceType {
  article
  video
  course
  interactive
  docs
  book
}

enum ResourceTier {
  core
  optional
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum Origin {
  seed
  agent
  user
}

enum SourceKind {
  official_docs
  educator
  course_platform
  textbook
  community
}

enum ResourceStatus {
  active
  deprecated
  pending_review
}

// Severity of a pending-review rejection. `soft` — quality downgrade, future
// tracks only. `hard` — broken/dead link, may warrant patching in-flight
// learners once the Track layer exists.
enum DeprecationSeverity {
  soft
  hard
}

// Phase 2.5: lifecycle of a Resource w.r.t. container/atomic decomposition.
// `atomic` — a single, pickable unit (default; all pre-2.5 rows backfilled here).
// `decomposed` — a container whose children have been materialized; not pickable itself.
// `pending` — discovered as a container, decomposition deferred/in-flight; not pickable.
// `unsupported` — decomposer cannot handle this type (e.g. paywalled course); not pickable.
// `human_review` — needs manual curation before pickable.
enum DecompositionStatus {
  atomic
  decomposed
  pending
  unsupported
  human_review
}

// Phase 2 keeps User minimal. Auth fields (email, supabaseId, etc.) land in
// Phase 3 with Supabase Google OAuth. Paid status is derived from Subscription.
model User {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscription  Subscription?
  createdPaths  Path[]
  enrollments   EnrolledPath[]
  progress      Progress[]
}

// Scaffold only — Phase 3 (Stripe) will extend with stripeCustomerId,
// stripeSubscriptionId, currentPeriodEnd, cancellation reasons, etc. `status`
// is a free-form string so we don't lock an enum before Stripe dictates the
// vocabulary. Splitting this from User now (rather than a `plan` column)
// acknowledges that billing concerns belong in their own aggregate.
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("inactive")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Generation inputs live on Path (not EnrolledPath) because they shape the
// agent's content selection — prior knowledge gates which prereqs to skip,
// timeframe + hours/week trim optional items and bias toward shorter
// resources. Storing them here makes the path reproducible and the per-item
// rationale auditable ("why this fits a 6-week beginner at 4 hrs/week").
// Trade-off: less Path reuse across users with similar-but-different inputs;
// acceptable because (a) "no caching, same input = fresh path" is locked, and
// (b) dedup, if it becomes worthwhile, belongs at the agent layer.
model Path {
  id                   String         @id @default(cuid())
  topic                String
  title                String
  summary              String
  difficulty           Difficulty
  inputPriorKnowledge  String?
  inputTimeframeWeeks  Int?
  inputHoursPerWeek    Int?
  createdById          String?
  createdBy            User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  // Phase 2.5c: readiness gate. The map-builder authors the spine synchronously
  // and flips the Path to `spine_ready`; the first Track build is gated on it.
  // `draft` (pre-spine) → `building` (spine in flight) → `spine_ready` | `failed`.
  status               PathStatus     @default(draft)
  items                PathItem[]
  // Phase 2.5c: Path becomes an input-agnostic concept map for a whole topic —
  // one Path per canonical topic, hence @@unique([topic]). The user-specific
  // columns above (createdById, difficulty, input*, title) retire WITH PathItem
  // at the 2.5f cutover, not in this block.
  concepts             Concept[]
  tracks               Track[]
  enrollments          EnrolledPath[]
  remediationJobs      RemediationJob[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([topic])
  @@index([createdById])
}

// Phase 2.5c: Path readiness lifecycle for the spine-ready gate (see Path.status).
enum PathStatus {
  draft
  building
  spine_ready
  failed
}

model PathItem {
  id            String         @id @default(cuid())
  pathId        String
  path          Path           @relation(fields: [pathId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      Resource       @relation(fields: [resourceId], references: [id])
  order         Int
  rationale     String
  status        PathItemStatus @default(active)
  // Phase-5 scaffolding — created here per the locked plan but inert until
  // the adaptive-branch feature lands. `branchOnFail` is a plain nullable
  // string (not an FK) so Phase 5 can decide whether it points to a
  // PathItem id, a Resource id, or something else without a migration.
  isCheckpoint  Boolean        @default(false)
  branchOnFail  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([pathId, order])
  @@index([resourceId])
}

enum PathItemStatus {
  active
  removed
}

// Phase 2.5c: enrollment keys on the pinned Track (the immutable instance the
// learner walks), not the Path. `pathId` is kept denormalized for cross-version
// queries ("all enrollments under this map"). Inert today — zero consumers — so
// re-keying the PK to trackId is free; trackId is required for the same reason.
model EnrolledPath {
  userId     String
  trackId    String
  pathId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  path       Path     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@id([userId, trackId])
  @@index([pathId])
  @@index([trackId])
}

// Phase 2.5c: progress re-keys from PathItem to Lesson — the Lesson is the
// completable unit in the Track delivery shape. Inert today (zero consumers), so
// the re-key is free. The table is empty, which is what makes the migration's
// `lessonId NOT NULL`-with-no-default safe — do NOT copy that onto a populated table.
model Progress {
  userId      String
  lessonId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@id([userId, lessonId])
  @@index([lessonId])
}

// Phase 2.5 — delivery structure built on top of a Path.
// 1:1 with Path today but kept as a separate aggregate: Path is the curriculum
// agent's selection record (what + why); Track is the post-processed, dedup'd
// delivery shape with generated content. Regenerable without re-running
// expensive library matching + web fallback.
model Track {
  id        String      @id @default(cuid())
  // Phase 2.5c: dropped @unique — one Path (concept map) → many Tracks (learner
  // traversals). The per-learner inputs + user-facing title/summary that used to
  // live on Path move here; nullable for now since the builder (2.5e) populates
  // them and the table is empty.
  pathId    String
  path      Path        @relation(fields: [pathId], references: [id], onDelete: Cascade)
  status    TrackStatus @default(pending)
  priorKnowledge String?
  timeframeWeeks Int?
  hoursPerWeek   Int?
  // Phase 2.5e: the learner's target mastery for this Track. Reuses the
  // Difficulty enum so the Track composer can difficulty-match a concept's
  // primary resource against the target, and so `targetMastery` drives how deep
  // into the frontier the build reaches (advanced pulls more frontier than
  // beginner). Nullable like the other inert Track inputs; the builder defaults
  // null → beginner.
  targetMastery  Difficulty?
  // Phase 2.5e-6: `goal` is the learner's own free-text statement of why they're
  // taking this Track ("refresh calc before grad school", "drill for my exam");
  // `intent` is the coarse category the composer INFERS from that goal (+ prior
  // knowledge) in its one judgment pass and emits as structured output. We keep the
  // inferred label as a queryable column so deterministic downstream code (the
  // 2.5e-7 allocator) can branch on it and so intent is analyzable — the raw goal
  // is data, the enum is the decision. Both nullable like the other Track inputs;
  // the builder defaults a missing intent to `learn` (a fresh first pass).
  goal           String?
  intent         TrackIntent?
  title          String?
  summary        String?
  lessons     Lesson[]
  sections    Section[]
  enrollments EnrolledPath[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([pathId])
}

enum TrackStatus {
  pending
  building
  ready
  failed
}

// Phase 2.5e-6: why the learner is taking this Track, inferred by the composer
// from their free-text goal. Shapes pruning + (2.5e-7) time allocation:
//   learn     — fresh first pass; full depth, teach from first principles.
//   review    — refresh material they once knew; prune known spine readily, prefer
//               short refreshers + practice over long first-principles lectures.
//   practice  — drilling/application over new exposition; bias toward exercises.
//   master    — go deep / internalize beyond a first pass (depth of engagement;
//               orthogonal to targetMastery, which is the level ceiling of material).
//   exam_prep — time-boxed, breadth-first cram against an assessment.
enum TrackIntent {
  learn
  review
  practice
  master
  exam_prep
}

model Lesson {
  id              String           @id @default(cuid())
  trackId         String
  track           Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  orderInTrack    Int
  title           String
  summary         String
  conceptsTaught  String[]
  estMinutes      Int
  // Phase 2.5e (track sections): the chapter this lesson belongs to. Nullable so a
  // flat, un-sectioned Track is always valid — sectioning is a best-effort
  // post-build LLM pass (sectioner.ts), so a Track may render flat if it never ran,
  // failed, or was too short to section. SetNull (not Cascade): deleting a Section
  // ungroups its lessons rather than destroying them.
  sectionId       String?
  section         Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  resources       LessonResource[]
  exercises       Exercise[]
  progress        Progress[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([trackId, orderInTrack])
  @@index([sectionId])
}

// Phase 2.5e (track sections): a named chapter grouping a contiguous run of a
// Track's Lessons, with a short learner-facing intro. Built by the post-build
// sectioner (sectioner.ts / section-track.ts) — a separate LLM pass that groups
// the already-ordered, already-trimmed lessons, so a Section is always a
// contiguous run of `orderInTrack` and never references a budget-trimmed lesson.
// A Section is the "contentless chapter divider": it owns title + intro but holds
// no resources of its own, so the playground can render a header without
// fabricating a filler Lesson. Re-sectioning is idempotent (delete + recreate).
model Section {
  id           String   @id @default(cuid())
  trackId      String
  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  orderInTrack Int
  title        String
  intro        String?
  lessons      Lesson[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // No separate @@index([trackId]): the composite unique above already provides a
  // trackId left-prefix index for the sectioner/renderer's trackId-only lookups.
  @@unique([trackId, orderInTrack])
}

// Join row between a Lesson and a Resource. `role` distinguishes the canonical
// resource from alternates surfaced via cross-resource concept dedup.
// `deliveryMode` is per-resource-in-this-context (a single Lesson may mix an
// embeddable video, a new-tab article, and a native exercise). `segmentRef`
// carries YouTube timestamps / doc anchors when only part of a resource is used.
model LessonResource {
  id           String             @id @default(cuid())
  lessonId     String
  lesson       Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  resourceId   String
  resource     Resource           @relation(fields: [resourceId], references: [id])
  role         LessonResourceRole @default(primary)
  // Phase 2.5e-7b: render/selection order WITHIN a lesson. The allocator emits a
  // ranked list — the mandatory complementary core (multiple role=primary rows) in
  // priority order, then the optional/alternate substitute pool. One sequence per
  // lesson (primaries 1..k first, then alternates); `role` distinguishes core vs
  // optional. @default(0) covers pre-2.5e-7b rows; the builder always sets it.
  orderInLesson Int               @default(0)
  deliveryMode DeliveryMode
  segmentRef   Json?
  createdAt    DateTime           @default(now())

  @@unique([lessonId, resourceId])
  @@index([lessonId])
  @@index([resourceId])
}

enum LessonResourceRole {
  primary
  alternate
}

enum DeliveryMode {
  embed
  newtab
  native
}

// Agent-generated practice attached to a Lesson. `kind` is intentionally narrow
// for 2.5e (text/MCQ); broaden when later kinds (code, etc.) ship.
model Exercise {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  prompt    String
  answer    String
  rubric    String
  kind      ExerciseKind
  origin    Origin       @default(agent)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([lessonId])
}

enum ExerciseKind {
  text
  mcq
}

// Phase 2.5c — Topic Concept Map. A Concept is a Path-scoped node in the topic's
// prerequisite DAG. Canonicalization is a within-one-map match-or-create on the
// per-Path `slug` (never global — see ROADMAP "Why Path-scoped"). `membership`
// splits the required backbone (`spine`, gates the first Track) from opt-in
// enrichment (`frontier`, thickened async).
model Concept {
  id         String            @id @default(cuid())
  pathId     String
  path       Path              @relation(fields: [pathId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  membership ConceptMembership @default(spine)
  // Phase 2.5f: set when remediation, unable to source a `teaches` candidate at
  // or above MAP_SPINE_MIN_PRIMARY_COVERAGE, accepts the best available sub-floor
  // primary so the learner still gets a (weaker) course. Readiness (2.5f-3) treats
  // a relaxed concept with any candidate as covered, not a spine hole. Column only
  // this block; the readiness honoring + the writer land in 2.5f-3.
  primaryRelaxed Boolean        @default(false)
  // Prereq edges in both directions: `prereqsOut` are edges where this concept
  // is the prerequisite; `prereqsIn` are edges where it is the dependent.
  prereqsOut ConceptPrereq[]   @relation("PrereqFrom")
  prereqsIn  ConceptPrereq[]   @relation("PrereqTo")
  resources  ConceptResource[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([pathId, slug])
  @@index([pathId, membership])
}

enum ConceptMembership {
  spine
  frontier
}

// Phase 2.5c — a directed prerequisite edge within one Path's concept DAG.
// `from → to` reads "learn `from` before `to`": `from` is the prerequisite, `to`
// depends on it. `pathId` is denormalized so the Track builder can load the whole
// map's edges in one indexed query (and as an integrity anchor that every edge
// stays intra-Path). Cycle-freeness is a DAG invariant the builder validates at
// write; the DB enforces only no-duplicate-edges and (via migration CHECK) no
// self-loop.
model ConceptPrereq {
  id            String  @id @default(cuid())
  pathId        String
  fromConceptId String
  toConceptId   String
  from          Concept @relation("PrereqFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  to            Concept @relation("PrereqTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([fromConceptId, toConceptId])
  @@index([toConceptId])
  @@index([pathId])
}

// Phase 2.5c — candidate link between a Concept and a pickable Resource. `role`
// distinguishes how the resource serves the concept (a Resource serves exactly
// one purpose, hence one role per pair — @@unique([conceptId, resourceId])).
// `coverageScore` ranks candidates so the Track builder picks a `primary` greedily
// and freezes the rest as `alternate` LessonResources. The resourceId index backs
// the 2.5f reject-pipeline reach-in (find concepts depending on a deprecated row).
model ConceptResource {
  id            String              @id @default(cuid())
  conceptId     String
  concept       Concept             @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      Resource            @relation(fields: [resourceId], references: [id])
  role          ConceptResourceRole @default(teaches)
  coverageScore Float
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([conceptId, resourceId])
  @@index([conceptId])
  @@index([resourceId])
}

enum ConceptResourceRole {
  teaches
  uses
  assesses
}

// Phase 2.5f — the durable record + single-flight claim for one spine-hole
// remediation pass over a Path. A `building` Path (or a hard-deprecation
// regression) gets ONE active job; concurrent claims are blocked by a PARTIAL
// unique index on (pathId) WHERE state IN ('queued','running') — Prisma can't
// express partial indexes, so that index is created in raw SQL in the migration
// (NOT here). Terminal rows (succeeded/failed/escalated) accumulate as an audit
// trail and don't block a future re-claim. The async poller + request-path
// enqueue that drive this automatically are 2.5g; this block invokes it manually.
model RemediationJob {
  id     String           @id @default(cuid())
  pathId String
  path   Path             @relation(fields: [pathId], references: [id], onDelete: Cascade)
  state  RemediationState @default(queued)
  // Set when state→running; the basis for stale-claim reclaim (a job whose worker
  // died mid-run), which the 2.5g poller acts on. The manual driver uses --force.
  claimedAt             DateTime?
  // The spine-hole slugs this job set out to fix (snapshot at claim time).
  holeSlugs             String[]
  // Concepts where remediation accepted a sub-floor best-effort primary (relaxed
  // the bar) so the Path could still reach spine_ready.
  relaxedConceptSlugs   String[]  @default([])
  // Concepts left uncoverable even after sourcing — parked in the review queue and
  // (2.5g) paged. The Path stays `building`; the job lands `escalated`.
  escalatedConceptSlugs String[]  @default([])
  // Failure diagnostic when state=failed (an unexpected error, not an escalation).
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([pathId])
}

enum RemediationState {
  queued
  running
  succeeded
  failed
  // Finished, but ≥1 concept was left uncoverable (Path remains `building`).
  escalated
}
