# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# backup files
/backups
*.bak
*.backup
*.orig
*~

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# claude code local files (CLAUDE.md and shared skills are tracked; the rest is local)
.claude/*
!.claude/skills/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local DB content snapshots (2.5h reset script)
backups/
